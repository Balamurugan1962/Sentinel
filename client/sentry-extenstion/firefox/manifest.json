{
  "manifest_version": 2,
  "name": "Sentinel",
  "version": "1.0",
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "permissions": [
    "webNavigation",
    "webRequest",
    "webRequestBlocking",
    "tabs",
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "sentinel@trivara.com",
      "strict_min_version": "91.0"
    }
  },
  "web_accessible_resources": ["blocked.html"]
}
